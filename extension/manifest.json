{
    "manifest_version": 3,
    "name": "ANS archiver",
    "version": "1.0",

    "description": "Download your exams and answers as PDF from ANS.",

    "content_scripts": [
        {
            "matches": ["*://ans.app/*"],
            "js": ["dist/content/content.js"]
        },
        {
            "matches": ["*://ans.app/*"],
            "js": ["dist/world.js"],
            "world": "MAIN"
        },
        {
            "matches": ["*://ans.app/*"],
            "css": ["dist/styles.css"]
        },
        {
            "matches": ["*://ans.app/?print_pdf=true*"],
            "js": ["dist/content/replacing_content.js"]
        }
    ],
    "web_accessible_resources": [
        {
            "resources": ["node_modules/@bentopdf/pymupdf-wasm/assets/*"],
            "matches": ["<all_urls>"]
        },
        {
            "resources": ["page.html"],
            "matches": ["<all_urls>"]
        }
    ],
    "background": {
        "scripts": ["dist/background.js"],
        "service_worker": "dist/background.js"
    },
    "host_permissions": [
        "*://*.ans.app/",
        "chrome-extension://*/page.html",
        "<all_urls>"
    ],
    "permissions": [
        "cookies",
        "activeTab",
        "tabs",
        "<all_urls>",
        "debugger",
        "scripting"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "ans@superlee",
            "data_collection_permissions": {
                "required": ["none"]
            }
        }
    }
}
